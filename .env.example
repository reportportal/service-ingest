# Server configuration
PORT=8080
HOST=0.0.0.0
BASE_PATH=/api

# Logging configuration
LOG_LEVEL=debug
LOG_HTTP_LEVEL=warn
LOG_FORMAT=text
LOG_ADD_RESPONSE_BODY=false
LOG_ADD_SOURCE=false

# Buffer
BUFFER_PATH=./data/buffer
BUFFER_CACHE_SIZE=1GiB
FILE_BUFFER_PATH=./data/staging

# Filesystem storage configuration
STORAGE_TYPE=fs
CATALOG_PATH=./data/catalog

# S3 storage configuration
STORAGE_TYPE=s3
CATALOG_PATH=/catalog
S3_BUCKET=
S3_REGION=
S3_ENDPOINT=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_SESSION_TOKEN=

# Parquet configuration
PARQUET_COMPRESSION=snappy
PARQUET_ROW_GROUP_SIZE=1000

# Processor
READ_LIMIT=100000
FLUSH_INTERVAL=5s
FILES_FLUSH_INTERVAL=10s
